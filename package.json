{
  "name": "KoreShelf",
  "version": "2.2.3",
  "private": true,
  "type": "module",
  "bin": "build-output/server.bundle.js",
  "pkg": {
    "assets": [
      "dist/**/*"
    ],
    "targets": [
      "node18-win-x64",
      "node18-linux-x64",
      "node18-macos-x64"
    ],
    "outputPath": "build-output"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "concurrently \"node server.js\" \"npm run dev\""
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.0",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.4.2",
    "@capawesome/capacitor-file-picker": "^8.0.3",
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.43",
    "axios": "^1.15.2",
    "better-sqlite3": "^11.10.0",
    "cheerio": "^1.0.0-rc.12",
    "dexie": "^4.4.4",
    "epub2": "^3.0.2",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "html-to-text": "^9.0.5",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.1",
    "sharp": "^0.32.6",
    "three": "^0.184.0",
    "uuid": "^14.0.0"
  }
}
