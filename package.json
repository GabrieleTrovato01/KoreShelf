{
  "name": "KoreShelf",
  "version": "2.0.1",
  "private": true,
  "type": "module",
  "bin": "build-output/server.bundle.js",
  "pkg": {
    "assets": [
      "dist/**/*"
    ],
    "targets": [
      "node18-win-x64",
      "node18-linux-x64",
      "node18-macos-x64"
    ],
    "outputPath": "build-output"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "concurrently \"node server.js\" \"npm run dev\""
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.0",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.43",
    "axios": "^1.15.2",
    "cheerio": "^1.2.0",
    "epub2": "^3.0.2",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "html-to-text": "^10.0.0",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.1",
    "pdf2pic": "^3.0.0",
    "sharp": "^0.32.6",
    "three": "^0.184.0",
    "uuid": "^14.0.0"
  }
}
